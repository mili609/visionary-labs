# Copy this file to .env.local for local development.
# Do not commit real secrets or private AWS credentials.

# Public site origin used for canonical URLs, Open Graph metadata, robots, and sitemap.
NEXT_PUBLIC_SITE_URL=https://myopreva.com

# Optional browser-visible API endpoint for future form submission.
# Leave blank until a production API route, API Gateway, or backend service exists.
NEXT_PUBLIC_API_BASE_URL=
